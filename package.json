{
  "name": "discord-tournament-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "register:commands": "tsx scripts/register-commands.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "fastify": "^5.3.3",
    "pino": "^9.2.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
